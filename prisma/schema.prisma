// L'Agence en Ligne — Schéma de base de données consolidé
// PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// UTILISATEURS ET AUTHENTIFICATION
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  prenom    String
  nom       String
  telephone String?
  role      String   @default("NEGOCIATEUR")
  // Rôles: ADMIN, SOUS_ADMIN, DIRECTEUR, MANAGER, NEGOCIATEUR, CLIENT_ACQUEREUR, CLIENT_VENDEUR
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  client          Client?
  negotiations    NegociationMove[]  @relation("AuthorMoves")
  clientsAssignes Client[]           @relation("NegociateurClients")
  contentEdits    PageContent[]      @relation("ContentEditor")
}

// ============================================
// CLIENTS (ACQUÉREURS & VENDEURS)
// ============================================

model Client {
  id        String   @id @default(cuid())
  numero    String   @unique // Numéro de série (ACQ-00001, VND-00001)
  prenom    String
  nom       String
  email     String   @unique
  telephone String?
  budgetMax Float? // Budget max en euros (acquéreur)
  prixIdeal Float? // Prix idéal souhaité (acquéreur)
  notes     String? // Notes synthétiques
  source    String   @default("MANUEL")
  // Sources: QCM, SITE, CRM, EXTERIEUR, LOVABLE, MANUEL, CHATBOT, FORMULAIRE
  typeClient String  @default("ACQUEREUR") // ACQUEREUR ou VENDEUR
  statut     String  @default("PROSPECT") // Pipeline Kanban
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Lien vers le compte utilisateur (optionnel)
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Négociateur assigné
  negociateurId String?
  negociateur   User? @relation("NegociateurClients", fields: [negociateurId], references: [id])

  // Infos Vendeur spécifiques
  prixVente       Float?
  adresseBien     String?
  villeVente      String?
  surfaceBien     Float?
  typeBienVente   String?
  descriptionBien String?
  financementOk   Boolean?

  // Mandat de recherche
  mandatNumero    String?   @unique
  mandatSigne     Boolean   @default(false)
  mandatDate      DateTime?
  mandatSignature String?
  mandatIP        String?
  mandatUserAgent String?
  mandatToken     String?   @unique
  mandatPdfPath   String?

  // Relations
  biens          Bien[]
  appels         Appel[]
  visites        Visite[]
  photosVente    PhotoVente[]
  historiquePrix HistoriquePrix[]
  documents      Document[]
  checklist      ChecklistItem[]
  qcmSubmissions QcmSubmission[]
}

// ============================================
// APPELS & CONTACTS
// ============================================

model Appel {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  duree         Int? // Durée en minutes
  type          String   @default("ENTRANT") // ENTRANT, SORTANT
  notes         String?
  interlocuteur String?
  telephone     String?
  createdAt     DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ============================================
// VISITES
// ============================================

model Visite {
  id         String   @id @default(cuid())
  dateVisite DateTime
  creneau    String? // ex: "mardi_matin", "jeudi_aprem"
  statut     String   @default("PLANIFIEE") // PLANIFIEE, REALISEE, ANNULEE, REPORT
  compteRendu   String?
  avisAcquereur String? // OUI, NON, REFLEXION
  montantOffre  Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Visiteur (acquéreur potentiel)
  visiteurNom       String?
  visiteurPrenom    String?
  visiteurEmail     String?
  visiteurTelephone String?
  financementOk     Boolean?

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  bienId String?
  bien   Bien?  @relation(fields: [bienId], references: [id])
}

// ============================================
// PHOTOS VENDEUR
// ============================================

model PhotoVente {
  id        String   @id @default(cuid())
  url       String
  nom       String?
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ============================================
// HISTORIQUE DES PRIX
// ============================================

model HistoriquePrix {
  id            String   @id @default(cuid())
  prix          Float
  prixPrecedent Float?
  commentaire   String?
  createdAt     DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ============================================
// BIENS IMMOBILIERS
// ============================================

model Bien {
  id               String   @id @default(cuid())
  lienAnnonce      String?
  prixAffiche      Float
  prixActuel       Float?
  ville            String?
  codePostal       String?
  localisation     String?
  surface          Float?
  typeBien         String? // APPARTEMENT, MAISON, IMMEUBLE, FONDS_COMMERCE, LOCAL_COMMERCIAL
  statut           String   @default("NOUVEAU")
  commentaireFinal String?
  sourceData       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  vendeur      Vendeur?
  photos       Photo[]
  negociations NegociationMove[]
  visites      Visite[]
  documents    Document[]
  checklist    ChecklistItem[]
}

// ============================================
// VENDEURS (un vendeur par bien)
// ============================================

model Vendeur {
  id        String   @id @default(cuid())
  nom       String?
  telephone String?
  email     String?
  notes     String?
  contexte  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bienId String @unique
  bien   Bien   @relation(fields: [bienId], references: [id], onDelete: Cascade)
}

// ============================================
// NÉGOCIATION PING-PONG
// ============================================

model NegociationMove {
  id          String   @id @default(cuid())
  ordre       Int // Numéro d'ordre chronologique
  camp        String // ACQUEREUR ou VENDEUR
  typeMove    String // OFFRE, CONTRE_OFFRE, REPONSE, COMMENTAIRE
  montant     Float?
  statut      String? // ACCEPTE, REFLECHIR, REFUS, SANS_SUITE
  commentaire String?
  interne     Boolean  @default(false) // Note interne (invisible client)
  createdAt   DateTime @default(now())

  bienId   String
  bien     Bien  @relation(fields: [bienId], references: [id], onDelete: Cascade)
  auteurId String?
  auteur   User? @relation("AuthorMoves", fields: [auteurId], references: [id])
}

// ============================================
// PHOTOS DES BIENS
// ============================================

model Photo {
  id        String   @id @default(cuid())
  url       String
  nom       String?
  createdAt DateTime @default(now())

  bienId String
  bien   Bien   @relation(fields: [bienId], references: [id], onDelete: Cascade)
}

// ============================================
// PARAMÈTRES DE L'APPLICATION
// ============================================

model Parametres {
  id          String   @id @default("default")
  mandatTexte String? // Texte personnalisé du mandat
  updatedAt   DateTime @updatedAt
}

// ============================================
// CMS — CONTENU DES PAGES DU SITE
// ============================================

model PageContent {
  id         String   @id @default(cuid())
  pageSlug   String // "homepage", "negocier", "vendre", "tarifs", etc.
  sectionKey String // "hero_title", "hero_subtitle", "cta_text", etc.
  content    String // Le texte ou le lien
  type       String   @default("text") // text, richtext, link, image
  updatedAt  DateTime @updatedAt

  updatedById String?
  updatedBy   User?  @relation("ContentEditor", fields: [updatedById], references: [id])

  @@unique([pageSlug, sectionKey])
  @@index([pageSlug])
}

// ============================================
// QCM — SOUMISSIONS DE QUIZ
// ============================================

model QcmSubmission {
  id          String   @id @default(cuid())
  prenom      String
  email       String
  score       Int
  scoreNego   Int?
  scoreLoi    Int?
  scorePsy    Int?
  scoreMarche Int?
  scoreRisque Int?
  scorePosture Int?
  answers     String? // JSON des réponses
  createdAt   DateTime @default(now())

  // Lien optionnel avec un client créé auto
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  @@index([email])
}

// ============================================
// BARÈME D'HONORAIRES
// ============================================

model Honoraires {
  id          String   @id @default(cuid())
  typeBien    String // APPARTEMENT, MAISON, FONDS_COMMERCE, IMMEUBLE, ACQUEREUR
  condition   String? // "< 400 000 EUR", etc.
  montant     String // "4 000 EUR", "10%", etc.
  description String?
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// ============================================
// DOCUMENTS & PIÈCES JOINTES
// ============================================

model Document {
  id            String    @id @default(cuid())
  nom           String
  type          String // MANDAT, OFFRE, COMPROMIS, PIECE_DOSSIER, AUTRE
  url           String // URL Supabase Storage ou Google Drive
  taille        Int? // Taille en bytes
  mimeType      String?
  signe         Boolean   @default(false)
  signatureUrl  String? // Image de la signature
  signatureDate DateTime?
  createdAt     DateTime  @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  bienId String?
  bien   Bien?  @relation(fields: [bienId], references: [id])

  @@index([clientId])
  @@index([bienId])
}

// ============================================
// CHECKLIST DOSSIER NOTAIRE
// ============================================

model ChecklistItem {
  id          String   @id @default(cuid())
  label       String
  obligatoire Boolean  @default(true)
  complete    Boolean  @default(false)
  documentId  String? // Lien vers le document uploadé
  notes       String?
  ordre       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  bienId String?
  bien   Bien?  @relation(fields: [bienId], references: [id])

  @@index([clientId])
}
